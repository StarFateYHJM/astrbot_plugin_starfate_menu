{
    "trigger_commands": {
        "type": "list",
        "description": "触发菜单的命令，私聊群聊通用",
        "items": {"type": "string"},
        "default": ["/menu", "/菜单", "/功能", "/帮助", "/sfmenu"]
    },
    "group_require_at": {
        "type": "bool",
        "description": "群聊是否需要艾特机器人才能触发",
        "default": true
    },
    "menu_categories": {
        "type": "template_list",
        "description": "菜单分类管理，点击展开编辑分类",
        "templates": {
            "default": {
                "name": "新分类",
                "items": {
                    "category_name": {
                        "type": "string",
                        "description": "分类名称",
                        "default": "新分类"
                    },
                    "category_icon": {
                        "type": "string",
                        "description": "分类图标，建议使用emoji",
                        "default": "📌"
                    },
                    "function_items": {
                        "type": "list",
                        "description": "该分类下的功能项，每项格式：功能名称 | 命令 | 描述",
                        "items": {"type": "string"},
                        "default": []
                    }
                }
            }
        },
        "default": [
            {
                "category_name": "基础功能",
                "category_icon": "📋",
                "function_items": [
                    "协议签订 | /协议 | 查看并签署用户协议"
                ]
            },
            {
                "category_name": "娱乐功能",
                "category_icon": "🎮",
                "function_items": [
                    "示例功能 | /example | 这是一个示例功能"
                ]
            }
        ]
    },
    "viewport_width": {
        "type": "int",
        "description": "图片渲染宽度（像素）",
        "default": 300,
        "min": 200,
        "max": 800
    },
    "css_zoom": {
        "type": "float",
        "description": "CSS缩放倍数，值越大图片越清晰但文件也越大",
        "default": 2.0,
        "min": 1.0,
        "max": 4.0,
        "step": 0.5
    },
    "background_color": {
        "type": "string",
        "description": "背景颜色，十六进制格式",
        "default": "#1A1A2E"
    },
    "title_text": {
        "type": "string",
        "description": "菜单标题文字",
        "default": "StarFate 功能菜单"
    },
    "title_color": {
        "type": "string",
        "description": "标题文字颜色",
        "default": "#E6B800"
    },
    "title_size": {
        "type": "int",
        "description": "标题字号（像素）",
        "default": 56,
        "min": 20,
        "max": 100
    },
    "category_color": {
        "type": "string",
        "description": "分类标题颜色",
        "default": "#00D2FF"
    },
    "category_size": {
        "type": "int",
        "description": "分类标题字号（像素）",
        "default": 40,
        "min": 16,
        "max": 80
    },
    "item_name_color": {
        "type": "string",
        "description": "功能名称颜色",
        "default": "#FFFFFF"
    },
    "item_name_size": {
        "type": "int",
        "description": "功能名称字号（像素）",
        "default": 32,
        "min": 14,
        "max": 60
    },
    "command_color": {
        "type": "string",
        "description": "命令文字颜色",
        "default": "#888888"
    },
    "command_size": {
        "type": "int",
        "description": "命令字号（像素）",
        "default": 28,
        "min": 12,
        "max": 50
    },
    "description_color": {
        "type": "string",
        "description": "功能描述文字颜色",
        "default": "#AAAAAA"
    },
    "description_size": {
        "type": "int",
        "description": "功能描述字号（像素）",
        "default": 26,
        "min": 12,
        "max": 50
    },
    "footer_text": {
        "type": "string",
        "description": "底部说明文字",
        "default": "发送对应命令即可使用功能"
    },
    "footer_color": {
        "type": "string",
        "description": "底部文字颜色",
        "default": "#666666"
    },
    "footer_size": {
        "type": "int",
        "description": "底部文字字号（像素）",
        "default": 28,
        "min": 12,
        "max": 50
    },
    "border_color": {
        "type": "string",
        "description": "分割线颜色",
        "default": "#333355"
    },
    "padding_body": {
        "type": "string",
        "description": "页面内边距，CSS格式如 60px 80px",
        "default": "60px 80px"
    }
}
