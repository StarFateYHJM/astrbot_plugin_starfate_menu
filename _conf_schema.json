{
    "trigger_commands": {
        "type": "list",
        "description": "全局触发命令",
        "items": {"type": "string"},
        "default": ["/menu", "/菜单", "/功能", "/帮助", "/sfmenu"]
    },
    "debug_mode": {
        "type": "bool",
        "description": "调试模式",
        "default": false
    },
    "menu_sets": {
        "type": "template_list",
        "description": "多菜单配置，每个菜单完全独立",
        "templates": {
            "default": {
                "name": "新菜单",
                "items": {
                    "menu_name": {
                        "type": "string",
                        "description": "菜单名称",
                        "default": "默认菜单"
                    },
                    "menu_id": {
                        "type": "string",
                        "description": "菜单ID（/menu id）",
                        "default": "default"
                    },
                    "is_default": {
                        "type": "bool",
                        "description": "是否为默认菜单",
                        "default": false
                    },
                    "pagination_enabled": {
                        "type": "bool",
                        "description": "是否启用分页",
                        "default": true
                    },
                    "items_per_page": {
                        "type": "int",
                        "description": "每页功能项数量",
                        "default": 10,
                        "min": 5,
                        "max": 30
                    },
                    "css_zoom": {
                        "type": "float",
                        "description": "CSS缩放倍数",
                        "default": 2.0,
                        "min": 1.0,
                        "max": 4.0,
                        "step": 0.5
                    },
                    "container_align": {
                        "type": "string",
                        "description": "对齐方式：left(左)、center(中)、right(右)",
                        "default": "center"
                    },
                    "title_text": {
                        "type": "string",
                        "description": "菜单标题",
                        "default": "功能菜单"
                    },
                    "footer_text": {
                        "type": "string",
                        "description": "底部文字",
                        "default": "发送对应命令即可使用功能"
                    },
                    "background_color": {
                        "type": "string",
                        "description": "背景颜色",
                        "default": "#1A1A2E"
                    },
                    "background_image": {
                        "type": "string",
                        "description": "背景图片URL",
                        "default": ""
                    },
                    "background_overlay": {
                        "type": "bool",
                        "description": "是否叠加遮罩",
                        "default": true
                    },
                    "overlay_color": {
                        "type": "string",
                        "description": "遮罩颜色",
                        "default": "#000000"
                    },
                    "overlay_opacity": {
                        "type": "float",
                        "description": "遮罩不透明度",
                        "default": 0.5,
                        "min": 0.0,
                        "max": 1.0,
                        "step": 0.1
                    },
                    "title_color": {
                        "type": "string",
                        "description": "标题颜色",
                        "default": "#E6B800"
                    },
                    "title_size": {
                        "type": "int",
                        "description": "标题字号",
                        "default": 56,
                        "min": 20,
                        "max": 100
                    },
                    "category_color": {
                        "type": "string",
                        "description": "分类标题颜色",
                        "default": "#00D2FF"
                    },
                    "category_size": {
                        "type": "int",
                        "description": "分类标题字号",
                        "default": 40,
                        "min": 16,
                        "max": 80
                    },
                    "item_name_color": {
                        "type": "string",
                        "description": "功能名称颜色",
                        "default": "#FFFFFF"
                    },
                    "item_name_size": {
                        "type": "int",
                        "description": "功能名称字号",
                        "default": 32,
                        "min": 14,
                        "max": 60
                    },
                    "command_color": {
                        "type": "string",
                        "description": "命令颜色",
                        "default": "#888888"
                    },
                    "command_size": {
                        "type": "int",
                        "description": "命令字号",
                        "default": 28,
                        "min": 12,
                        "max": 50
                    },
                    "description_color": {
                        "type": "string",
                        "description": "描述颜色",
                        "default": "#AAAAAA"
                    },
                    "description_size": {
                        "type": "int",
                        "description": "描述字号",
                        "default": 26,
                        "min": 12,
                        "max": 50
                    },
                    "footer_color": {
                        "type": "string",
                        "description": "底部颜色",
                        "default": "#666666"
                    },
                    "footer_size": {
                        "type": "int",
                        "description": "底部字号",
                        "default": 28,
                        "min": 12,
                        "max": 50
                    },
                    "border_color": {
                        "type": "string",
                        "description": "分割线颜色",
                        "default": "#333355"
                    },
                    "categories": {
                        "type": "list",
                        "description": "分类列表，格式：分类名 | 图标 | 功能1名称,命令,描述;功能2名称,命令,描述",
                        "items": {"type": "string"},
                        "default": []
                    }
                }
            }
        },
        "default": [
            {
                "menu_name": "默认菜单",
                "menu_id": "default",
                "is_default": true,
                "pagination_enabled": true,
                "items_per_page": 10,
                "css_zoom": 2.0,
                "container_align": "center",
                "title_text": "功能菜单",
                "footer_text": "发送对应命令即可使用功能",
                "background_color": "#1A1A2E",
                "background_image": "",
                "background_overlay": true,
                "overlay_color": "#000000",
                "overlay_opacity": 0.5,
                "title_color": "#E6B800",
                "title_size": 56,
                "category_color": "#00D2FF",
                "category_size": 40,
                "item_name_color": "#FFFFFF",
                "item_name_size": 32,
                "command_color": "#888888",
                "command_size": 28,
                "description_color": "#AAAAAA",
                "description_size": 26,
                "footer_color": "#666666",
                "footer_size": 28,
                "border_color": "#333355",
                "categories": []
            }
        ]
    }
}
